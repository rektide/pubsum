{
	"name": "pubsum",
	"version": "0.1.0",
	"description": "CLI tool to read chapters from epub files",
	"author": "rektide de la faye",
	"license": "MIT",
	"type": "module",
	"bin": {
		"pubsum": "./pubsum"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"test": "vp test",
		"typecheck": "tsgo --noEmit",
		"release": "bumpp",
		"prepublishOnly": "pnpm run build"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rektide/pub-sum.git"
	},
	"bugs": {
		"url": "https://github.com/rektide/pub-sum/issues"
	},
	"homepage": "https://github.com/rektide/pub-sum#readme",
	"dependencies": {
		"@lingo-reader/epub-parser": "^0.4.6",
		"@opencode-ai/sdk": "^1.15.10",
		"gunshi": "^0.32.0",
		"html-rewriter-wasm": "^0.4.1"
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"@typescript/native-preview": "7.0.0-dev.20260328.1",
		"bumpp": "^11.1.0",
		"typescript": "^6.0.3",
		"vite-plus": "latest",
		"vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.22"
	},
	"pnpm": {
		"overrides": {
			"vite": "npm:@voidzero-dev/vite-plus-core@latest",
			"vitest": "npm:@voidzero-dev/vite-plus-test@latest"
		}
	},
	"packageManager": "pnpm@10.33.0"
}
